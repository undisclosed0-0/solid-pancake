/* VITALS INITIAL + BOOT */
RPG.boot = () => {
  DKMap.renderNodes();
  DKMap.updatePlayer();
  RPG.Events.emit("log","Booting Dreamless Kingdom — Fractured Realm (Breathing Castle‑Grove landscape).");
  RPG.Events.emit("node:enter", RPG.Core.getCurrentNode());
  RPG.Events.emit("log","Type 'help' for commands.");
};

window.addEventListener("DOMContentLoaded", RPG.boot);
</script>
