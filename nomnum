}

#map-overlay {

position: relative;

width: 100%;

height: 100%;

max-height: 80vh;

overflow: auto;

}

#map-overlay svg {

display: block;

width: 100%;

height: auto;

}

#map-close {

position: absolute;

top: 10px;

right: 10px;

}

</style>

