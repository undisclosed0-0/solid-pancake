<script>

/* ============================

VIEW SWITCHING (TOP NAV)

============================= */

document.querySelectorAll('#site-nav a').forEach(link => {

link.addEventListener('click', () => {

const target = link.dataset.view;

// deactivate all views

document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));

// activate target view

const view = document.querySelector(`#view-${target}`);

if (view) view.classList.add('active');

// update nav active state

document.querySelectorAll('#site-nav a').forEach(a => a.classList.remove('active'));

link.classList.add('active');

// scroll to top for clean page/post feel

window.scrollTo({ top: 0, behavior: 'smooth' });

});

});

/* ============================

EDITOR TAB SWITCHING

============================= */

document.querySelectorAll('.editor-tabs button').forEach(tab => {

tab.addEventListener('click', () => {

const target = tab.dataset.tab;

// deactivate all tabs

document.querySelectorAll('.editor-tabs button')

.forEach(t => t.classList.remove('active'));

// activate clicked tab

tab.classList.add('active');

// deactivate all panels

document.querySelectorAll('.editor-panel')

.forEach(p => p.classList.remove('active'));

// activate target panel

const panel = document.querySelector(`#editor-${target}`);

if (panel) panel.classList.add('active');

});

});

</script>

<script>

/* =========================================================

0. UTILITIES

========================================================= */

function $(sel, root = document) {

return root.querySelector(sel);

}

function $all(sel, root = document) {

return Array.from(root.querySelectorAll(sel));

}

/* =========================================================

1. HASH ROUTING (TOP NAV + REFRESH SAFE)

========================================================= */

function activateView(viewName) {

$all('.view').forEach(v => v.classList.remove('active'));

const target = $(`#view-${viewName}`);

if (target) target.classList.add('active');

$all('#site-nav a').forEach(a => {

a.classList.toggle('active', a.dataset.view === viewName);

});

window.scrollTo({ top: 0, behavior: 'smooth' });

}

function handleHash() {

const hash = location.hash.replace('#', '');

const view = hash || 'home';

activateView(view);

}

window.addEventListener('hashchange', handleHash);

window.addEventListener('load', handleHash);

$all('#site-nav a').forEach(link => {

link.addEventListener('click', () => {

location.hash = link.dataset.view;

});

});

/* =========================================================

2. EDITOR TABS (MAP / ITEMS / MOBS / LOADERS)

========================================================= */

$all('.editor-tabs button').forEach(tab => {

tab.addEventListener('click', () => {

const target = tab.dataset.tab;

$all('.editor-tabs button').forEach(t => t.classList.remove('active'));

tab.classList.add('active');

$all('.editor-panel').forEach(p => p.classList.remove('active'));

const panel = $(`#editor-${target}`);

if (panel) panel.classList.add('active');

});

});

/* =========================================================

3. AUTOSAVE FOR FIELDS (LOCALSTORAGE)

========================================================= */

(function setupAutosave() {

const fields = $all('input, textarea, select');

fields.forEach(field => {

const key = `wb_${field.name || field.id || field.placeholder || ''}`;

if (!key) return;

const saved = localStorage.getItem(key);

if (saved !== null) field.value = saved;

field.addEventListener('input', () => {

localStorage.setItem(key, field.value);

});

});

})();

/* =========================================================

4. MAP: SVG LOADING + GRID FALLBACK

- If #map-svg exists, use it

- Else build a simple grid

========================================================= */

const mapGrid = $('.map-grid');

const mapDetails = $('.map-details');

const GRID_SIZE = 12;

function buildFallbackGrid() {

mapGrid.classList.add('grid-mode');

mapGrid.style.display = 'grid';

mapGrid.style.gridTemplateColumns = `repeat(${GRID_SIZE}, 1fr)`;

for (let i = 0; i < GRID_SIZE * GRID_SIZE; i++) {

const cell = document.createElement('div');

cell.className = 'map-cell';

cell.dataset.index = i;

mapGrid.appendChild(cell);

}

}

function attachMapInteractions(root) {

root.addEventListener('click', e => {

const cell = e.target.closest('.map-cell, [data-room-id]');

if (!cell) return;

$all('.map-cell, [data-room-id]', root).forEach(c => c.classList.remove('active'));

cell.classList.add('active');

const index = cell.dataset.index ?? '';

const roomId = cell.dataset.roomId ?? `room.${index}`;

const zone = cell.dataset.zone || 'Unknown Zone';

const type = cell.dataset.type || 'unknown';

const coord = cell.dataset.coord || '';

mapDetails.innerHTML = `

<h4>Selected Room</h4>

<p>ID: ${roomId}</p>

<p>Type: ${type}</p>

<p>Zone: ${zone}</p>

<p>Coordinate: ${coord}</p>

<button type="button" id="btn-edit-room">Edit Details</button>

<button type="button" id="btn-edit-zones">Edit Zones</button>

`;

setupRoomEditHandlers({ roomId, zone, type, coord, cell });

});

}

(function initMap() {

if (!mapGrid || !mapDetails) return;

const svg = $('#map-svg', mapGrid);

if (svg) {

// assume rooms are <g> or <rect> with data-room-id

$all('[data-room-id]', svg).forEach(el => {

el.classList.add('map-cell');

});

attachMapInteractions(svg);

} else {

buildFallbackGrid();

attachMapInteractions(mapGrid);

}

})();

/* =========================================================

5. ROOM EDITING MODAL

========================================================= */

let modalEl = null;

function openModal(contentHTML) {

if (!modalEl) {

modalEl = document.createElement('div');

modalEl.id = 'wb-modal';

modalEl.innerHTML = `

<div id="wb-modal-backdrop"></div>

<div id="wb-modal-dialog">

<div id="wb-modal-body"></div>

</div>

`;

document.body.appendChild(modalEl);

$('#wb-modal-backdrop', modalEl).addEventListener('click', closeModal);

}

$('#wb-modal-body', modalEl).innerHTML = contentHTML;

modalEl.classList.add('open');

}

function closeModal() {

if (modalEl) modalEl.classList.remove('open');

}

function setupRoomEditHandlers(room) {

const btnEditRoom = $('#btn-edit-room');

const btnEditZones = $('#btn-edit-zones');

if (btnEditRoom) {

btnEditRoom.onclick = () => {

openModal(`

<h3>Edit Room</h3>

<label>Room ID

<input type="text" id="edit-room-id" value="${room.roomId}">

</label>

<label>Type

<input type="text" id="edit-room-type" value="${room.type}">

</label>

<label>Zone

<input type="text" id="edit-room-zone" value="${room.zone}">

</label>

<label>Coordinate

<input type="text" id="edit-room-coord" value="${room.coord}">

</label>

<div style="margin-top:12px;display:flex;gap:8px;">

<button type="button" id="save-room">Save</button>

<button type="button" id="cancel-room" class="secondary">Cancel</button>

</div>

`);

$('#cancel-room').onclick = closeModal;

$('#save-room').onclick = () => {

const newId = $('#edit-room-id').value;

const newType = $('#edit-room-type').value;

const newZone = $('#edit-room-zone').value;

const newCoord = $('#edit-room-coord').value;

if (room.cell) {

room.cell.dataset.roomId = newId;

room.cell.dataset.type = newType;

room.cell.dataset.zone = newZone;

room.cell.dataset.coord = newCoord;

}

mapDetails.innerHTML = `

<h4>Selected Room</h4>

<p>ID: ${newId}</p>

<p>Type: ${newType}</p>

<p>Zone: ${newZone}</p>

<p>Coordinate: ${newCoord}</p>

<button type="button" id="btn-edit-room">Edit Details</button>

<button type="button" id="btn-edit-zones">Edit Zones</button>

`;

setupRoomEditHandlers({

roomId: newId,

type: newType,

zone: newZone,

coord: newCoord,

cell: room.cell

});

closeModal();

};

};

}

if (btnEditZones) {

btnEditZones.onclick = () => {

openModal(`

<h3>Zone Editor</h3>

<p>Assign this room to a zone or create a new one.</p>

<label>Zone Name

<input type="text" id="edit-zone-name" value="${room.zone}">

</label>

<div style="margin-top:12px;display:flex;gap:8px;">

<button type="button" id="save-zone">Save Zone</button>

<button type="button" id="cancel-zone" class="secondary">Cancel</button>

</div>

`);

$('#cancel-zone').onclick = closeModal;

$('#save-zone').onclick = () => {

const newZone = $('#edit-zone-name').value;

if (room.cell) {

room.cell.dataset.zone = newZone;

}

closeModal();

};

};

}

}

/* =========================================================

6. ITEM / MOB / LOADER JSON EXPORT

========================================================= */

function collectListItems(selector) {

return $all(selector).map(li => li.textContent.trim());

}

function collectMapData() {

return $all('.map-cell').map(c => ({

index: c.dataset.index ?? null,

roomId: c.dataset.roomId ?? null,

zone: c.dataset.zone ?? null,

type: c.dataset.type ?? null,

coord: c.dataset.coord ?? null

}));

}

function buildWorldPayload() {

const worldTitle = $('input[placeholder="World title"]')?.value || '';

const worldDesc = $('textarea[placeholder="Short description of this world"]')?.value || '';

return {

world: {

title: worldTitle,

description: worldDesc

},

map: collectMapData(),

items: collectListItems('#editor-items .editor-list li'),

mobs: collectListItems('#editor-mobs .editor-list li'),

loaders: collectListItems('#editor-loaders .editor-list li')

};

}

/* =========================================================

7. RPG SYNC PREVIEW + EXPORT HOOK

========================================================= */

const previewEl = $('#rpg-preview-json');

if (previewEl) {

setInterval(() => {

const payload = buildWorldPayload();

previewEl.textContent = JSON.stringify(payload, null, 2);

}, 1500);

}

// This is the single hook your RPG engine can call or listen to.

function exportToRpgEngine() {

const payload = buildWorldPayload();

// TODO: replace with your real integration:

// - postMessage to parent

// - fetch() to backend

// - window.RPG.importWorld(payload)

console.log('Exporting world to RPG engine:', payload);

alert('World exported to RPG engine (see console for payload).');

}

// Wire the "Export to RPG" button in RPG Bridge view

const exportBtn = document.querySelector('#view-bridge button');

if (exportBtn) {

exportBtn.addEventListener('click', exportToRpgEngine);

}

</script>

<script>

/* ============================

HASH ROUTER

============================= */

function activateView(viewName) {

document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));

const target = document.querySelector(`#view-${viewName}`);

if (target) target.classList.add('active');

document.querySelectorAll('#site-nav a').forEach(a => {

a.classList.toggle('active', a.dataset.view === viewName);

});

window.scrollTo({ top: 0, behavior: 'smooth' });

}

function handleHash() {

const hash = location.hash.replace('#', '');

const view = hash || 'home';

activateView(view);

}

window.addEventListener('hashchange', handleHash);

window.addEventListener('load', handleHash);

document.querySelectorAll('#site-nav a').forEach(link => {

link.addEventListener('click', () => {

location.hash = link.dataset.view;

});

});

</script>

<script>

/* ============================

AUTOSAVE FOR ALL FIELDS

============================= */

const fields = document.querySelectorAll('input, textarea, select');

fields.forEach(field => {

const key = `wb_${field.name || field.id || field.placeholder}`;

// Load saved value

const saved = localStorage.getItem(key);

if (saved !== null) field.value = saved;

// Save on change

field.addEventListener('input', () => {

localStorage.setItem(key, field.value);

});

});

</script>

<script>

/* ============================

MAP GRID LOGIC

============================= */

const mapGrid = document.querySelector('.map-grid');

// Generate a 12×12 grid (change as needed)

const GRID_SIZE = 12;

for (let i = 0; i < GRID_SIZE * GRID_SIZE; i++) {

const cell = document.createElement('div');

cell.className = 'map-cell';

cell.dataset.index = i;

mapGrid.appendChild(cell);

}

mapGrid.addEventListener('click', e => {

if (!e.target.classList.contains('map-cell')) return;

document.querySelectorAll('.map-cell').forEach(c => c.classList.remove('active'));

e.target.classList.add('active');

const index = e.target.dataset.index;

const x = index % GRID_SIZE;

const y = Math.floor(index / GRID_SIZE);

document.querySelector('.map-details').innerHTML = `

<h4>Selected Room</h4>

<p>Index: ${index}</p>

<p>Coordinate: (${x}, ${y})</p>

<button>Edit Details</button>

<button>Edit Zones</button>

`;

});

</script>

