<style>/* ============================

ROOT THEME

============================= */

:root {

--bg-0: #0d0c11;

--bg-1: #15131c;

--bg-2: #1d1a25;

--bg-3: #262233;

--border: #2f2a3a;

--border-soft: #3a3546;

--text-0: #ffffff;

--text-1: #e7e6e6;

--text-2: #a7a4b2;

--text-3: #6f6b7a;

--accent-orange: #F77F27;

--accent-yellow: #F7C948;

--accent-teal: #27BEBE;

--radius-sm: 4px;

--radius-md: 8px;

--radius-lg: 12px;

--shadow-1: 0 8px 22px rgba(0,0,0,0.45);

--shadow-2: 0 14px 40px rgba(0,0,0,0.55);

}

/* ============================

BASE

============================= */

html, body {

margin: 0;

padding: 0;

background: radial-gradient(circle at top, #1b1824 0%, #0b0a0f 55%, #050408 100%);

color: var(--text-1);

font-family: "Roboto Slab", serif;

min-height: 100vh;

}

* {

box-sizing: border-box;

}

/* ============================

HEADER

============================= */

#site-header {

display: flex;

justify-content: space-between;

align-items: center;

padding: 18px 32px;

background: linear-gradient(90deg, #17141f, #1f1b29);

border-bottom: 1px solid var(--border);

box-shadow: var(--shadow-1);

position: sticky;

top: 0;

z-index: 20;

}

.brand-title {

font-family: "Brandon Grotesque", sans-serif;

font-size: 26px;

letter-spacing: 0.12em;

text-transform: uppercase;

margin: 0;

color: var(--accent-yellow);

}

.brand-subtitle {

margin: 0;

font-size: 13px;

color: var(--text-3);

}

#site-nav {

display: flex;

gap: 16px;

}

#site-nav a {

text-decoration: none;

color: var(--text-3);

font-size: 12px;

text-transform: uppercase;

letter-spacing: 0.12em;

padding: 6px 12px;

border-radius: 999px;

border: 1px solid transparent;

cursor: pointer;

transition: 0.15s ease;

}

#site-nav a:hover {

color: var(--accent-yellow);

border-color: rgba(247, 201, 72, 0.4);

background: rgba(247, 201, 72, 0.06);

}

/* ============================

MAIN CONTENT

============================= */

#content {

max-width: 1200px;

margin: 24px auto 40px;

padding: 0 20px;

}

.view {

display: none;

}

.view.active {

display: block;

}

/* ============================

TYPOGRAPHY

============================= */

h2 {

font-family: "Brandon Grotesque", sans-serif;

font-size: 22px;

letter-spacing: 0.08em;

text-transform: uppercase;

margin: 0 0 8px;

color: var(--text-0);

}

h3 {

font-family: "Brandon Grotesque", sans-serif;

font-size: 18px;

letter-spacing: 0.06em;

text-transform: uppercase;

margin: 0 0 6px;

color: var(--accent-yellow);

}

h4 {

font-family: "Brandon Grotesque", sans-serif;

font-size: 14px;

letter-spacing: 0.08em;

text-transform: uppercase;

margin: 0 0 6px;

color: var(--accent-teal);

}

/* ============================

POST FOLDS (HOME)

============================= */

.post-fold {

background: radial-gradient(circle at top left, #262133 0%, #17141f 55%, #120f18 100%);

border-radius: var(--radius-lg);

padding: 18px 20px;

margin-bottom: 18px;

border: 1px solid rgba(247, 201, 72, 0.18);

box-shadow: var(--shadow-2);

}

.feature-grid {

display: grid;

grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));

gap: 16px;

margin-top: 18px;

}

.feature {

background: var(--bg-2);

border-radius: var(--radius-md);

padding: 14px 16px;

border: 1px solid var(--border);

box-shadow: var(--shadow-1);

}

/* ============================

BUTTONS

============================= */

button {

font-family: "Brandon Grotesque", sans-serif;

font-size: 12px;

text-transform: uppercase;

letter-spacing: 0.12em;

padding: 8px 14px;

border-radius: 999px;

border: 1px solid var(--accent-orange);

background: var(--accent-orange);

color: #1a1208;

cursor: pointer;

transition: 0.15s ease;

}

button:hover {

background: #ff8f3a;

border-color: #ff8f3a;

transform: translateY(-1px);

}

button:active {

transform: translateY(0);

}

/* ============================

WORLD CARDS

============================= */

.world-list {

display: grid;

grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));

gap: 16px;

}

.world-card {

background: var(--bg-2);

border-radius: var(--radius-md);

padding: 14px 16px;

border: 1px solid var(--border);

box-shadow: var(--shadow-1);

}

.world-actions {

display: flex;

gap: 8px;

margin-top: 10px;

}

/* ============================

WORLD LOBBY

============================= */

.world-lobby {

display: grid;

grid-template-columns: 2fr 1fr;

gap: 20px;

margin-bottom: 24px;

}

.info-block {

background: var(--bg-2);

border-radius: var(--radius-md);

padding: 14px 16px;

border: 1px solid var(--border);

box-shadow: var(--shadow-1);

}

/* ============================

FORMS

============================= */

label {

display: block;

font-size: 12px;

text-transform: uppercase;

letter-spacing: 0.12em;

color: var(--text-3);

margin-bottom: 8px;

}

input,

select,

textarea {

width: 100%;

padding: 8px 10px;

border-radius: var(--radius-sm);

border: 1px solid #34313f;

background: #14121b;

color: var(--text-1);

font-size: 13px;

font-family: inherit;

outline: none;

transition: 0.15s ease;

}

input:focus,

select:focus,

textarea:focus {

border-color: var(--accent-teal);

box-shadow: 0 0 0 1px rgba(39, 190, 190, 0.4);

background: #181624;

}

/* ============================

EDITOR TABS

============================= */

.editor-tabs {

display: inline-flex;

gap: 8px;

margin-bottom: 20px;

padding: 4px;

border-radius: 999px;

background: #15131c;

border: 1px solid var(--border);

}

.editor-tabs button {

background: transparent;

border: 1px solid transparent;

color: var(--text-3);

}

.editor-tabs button.active {

background: var(--accent-orange);

color: #1a1208;

border-color: var(--accent-orange);

}

/* ============================

MAP EDITOR

============================= */

.map-editor {

display: grid;

grid-template-columns: 2fr 1.1fr;

gap: 20px;

margin-bottom: 20px;

}

.map-grid {

min-height: 220px;

border-radius: var(--radius-md);

background: radial-gradient(circle at top, #262133 0%, #17141f 55%, #120f18 100%);

border: 1px solid rgba(247, 127, 39, 0.35);

box-shadow: var(--shadow-2);

}

.map-details {

background: var(--bg-2);

border-radius: var(--radius-md);

padding: 12px 14px;

border: 1px solid var(--border);

box-shadow: var(--shadow-1);

}

/* ============================

TABLES

============================= */

table {

width: 100%;

border-collapse: collapse;

font-size: 13px;

}

thead {

background: #1f1c27;

}

th, td {

padding: 6px 8px;

text-align: left;

}

th {

font-family: "Brandon Grotesque", sans-serif;

text-transform: uppercase;

letter-spacing: 0.08em;

font-size: 11px;

color: var(--text-3);

border-bottom: 1px solid #2f2b3a;

}

tbody tr:nth-child(even) {

background: #17141f;

}

tbody tr:nth-child(odd) {

background: #14121b;

}

tbody tr:hover {

background: #211e2b;

}

/* ============================

RESPONSIVE

============================= */

@media (max-width: 900px) {

.world-lobby,

.map-editor,

.map-lists,

.editor-row {

grid-template-columns: 1fr;

}

}

@media (max-width: 600px) {

#site-header {

flex-direction: column;

align-items: flex-start;

gap: 10px;

}

#site-nav {

flex-wrap: wrap;

}

}

#wb-modal {

position: fixed;

inset: 0;

display: none;

align-items: center;

justify-content: center;

z-index: 100;

}

#wb-modal.open {

display: flex;

}

#wb-modal-backdrop {

position: absolute;

inset: 0;

background: rgba(0,0,0,0.65);

}

#wb-modal-dialog {

position: relative;

background: var(--bg-2);

border-radius: var(--radius-md);

border: 1px solid var(--border);

box-shadow: var(--shadow-2);

padding: 16px 18px;

max-width: 420px;

width: 100%;

z-index: 101;

}

.view {

opacity: 0;

transition: opacity .35s ease;

}

.view.active {

opacity: 1;

}

.map-grid {

display: grid;

grid-template-columns: repeat(12, 1fr);

gap: 2px;

}

.map-cell {

background: #1a1822;

border: 1px solid #2d2937;

height: 32px;

cursor: pointer;

transition: 0.15s ease;

}

.map-cell:hover {

background: #2a2634;

}

.map-cell.active {

background: var(--accent-orange);

border-color: var(--accent-orange);

}

.zone-highlight {

outline: 2px solid var(--accent-teal);

}

.type-highlight {

outline: 2px solid var(--accent-yellow);

}

#rpg-preview {

background: var(--bg-2);

border: 1px solid var(--border);

padding: 14px;

border-radius: var(--radius-md);

margin-top: 20px;

}

#rpg-preview pre {

white-space: pre-wrap;

font-size: 12px;

color: var(--text-2);

}

.hidden {

display: none;

}

.map-modal {

position: fixed;

inset: 0;

display: flex;

align-items: center;

justify-content: center;

z-index: 100;

}

.map-modal-backdrop {

position: absolute;

inset: 0;

background: rgba(0,0,0,0.7);

}

.map-modal-frame {

position: relative;

z-index: 101;

background: #111018;

border-radius: 12px;

border: 1px solid #2f2a3a;

padding: 12px;

max-width: 900px;

width: 100%;

max-height: 90vh;

box-shadow: 0 18px 50px rgba(0,0,0,0.7);

